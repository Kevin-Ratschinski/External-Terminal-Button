{
  "name": "external-terminal-button",
  "displayName": "External Terminal Button",
  "description": "Adds a status bar button to quickly open an external terminal",
  "version": "1.1.0",
  "publisher": "kratschinski",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kevin-Ratschinski/External-Terminal-Button"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "externalTerminalButton.openExternalTerminal",
        "title": "Open External Terminal",
        "category": "Terminal"
      }
    ],
    "configuration": {
      "title": "External Terminal Button",
      "properties": {
        "externalTerminalButton.alignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "description": "Status bar button alignment"
        },
        "externalTerminalButton.priority": {
          "type": "number",
          "default": 0,
          "description": "Status bar button priority (higher = further left)"
        },
        "externalTerminalButton.text": {
          "type": "string",
          "default": "$(terminal) Ext Terminal",
          "description": "Status bar button text (supports codicons)"
        },
        "externalTerminalButton.openInFileDirectory": {
          "type": "boolean",
          "default": false,
          "description": "Open the terminal in the directory of the currently active file instead of the workspace root"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
